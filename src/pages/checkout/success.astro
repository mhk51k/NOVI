---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Merci pour ta commande">
  <section class="mx-auto max-w-xl px-4 py-24 text-center sm:px-6 lg:px-8">
    <h1 class="text-ink text-3xl font-bold tracking-tight">Merci pour ta commande !</h1>
    <p class="text-muted mt-4">Un email de confirmation va t'être envoyé sous peu.</p>
    <a href="/" class="bg-brand mt-8 inline-flex min-h-[44px] items-center justify-center rounded-brand px-6 text-sm font-semibold text-white">
      Retour à l'accueil
    </a>
  </section>
</BaseLayout>
