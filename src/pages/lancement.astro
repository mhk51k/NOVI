---
// Page de lancement pour NOVI, la gamme d'enceinte portable.
// Photo produit générée via Higgsfield (src/assets/produit/novi-enceinte.png) — visuel de
// travail à remplacer par une vraie photo produit avant mise en production.
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import Logo from '@/components/ui/Logo.astro';
import noviEnceinte from '@/assets/produit/novi-enceinte.png';

const categories = ['Enceintes', 'Accessoires', 'Éditions limitées'];
---

<BaseLayout
  title="Lancement"
  description="NOVI, l'enceinte portable Bluetooth sans fil : autonomie longue durée, son puissant et habillage tissu résistant."
>
  <section class="novi-hero">
    <div class="novi-topbar">
      <span class="novi-logo-size"><Logo /></span>
      <span class="novi-meta">PARIS · 2026</span>
    </div>

    <div class="novi-grid">
      <div class="novi-headline-col">
        <h1 class="novi-headline">
          <span>Sans</span>
          <span>Fil</span>
        </h1>
        <p class="novi-copy">
          NOVI tient dans une main, se glisse dans un sac et diffuse un son puissant en Bluetooth
          du réveil à la dernière chanson du soir. Câble AUX et câble de charge inclus.
        </p>
      </div>

      <div class="novi-side-col">
        <p class="novi-tagline">Puissance<br />&amp; liberté</p>

        <div class="novi-visual">
          <Image
            src={noviEnceinte}
            alt="Enceinte portable NOVI, habillage tissu, format allongé façon JBL"
            width={800}
            height={600}
            class="novi-visual-img"
          />
        </div>

        <span class="novi-scroll">(défiler)</span>
      </div>
    </div>
  </section>

  <nav class="novi-categories" aria-label="Catégories de produits">
    {
      categories.map((label, i) => (
        <a href="/produit" class="novi-category-row" style={`--i:${i}`}>
          {label}
        </a>
      ))
    }
    <span class="novi-badge">Paiement sécurisé</span>
  </nav>
</BaseLayout>

<style>
  .novi-hero {
    /* Palette locale à cette page de campagne (noir/blanc/vert) — distincte des tokens globaux du site. */
    --novi-ink: #0a0a0a;
    --novi-bg: #ffffff;
    --novi-accent: #7cff3c;
    --novi-mono: ui-monospace, 'SFMono-Regular', Menlo, Consolas, monospace;

    background: var(--novi-bg);
    color: var(--novi-ink);
    padding: 1.5rem clamp(1.25rem, 4vw, 3rem) 3rem;
  }

  .novi-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: clamp(2rem, 6vw, 4rem);
  }

  .novi-logo-size {
    font-size: 1.25rem;
  }

  .novi-meta {
    font-family: var(--novi-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.05em;
  }

  .novi-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 6vw, 3rem);
  }

  @media (min-width: 900px) {
    .novi-grid {
      grid-template-columns: 1.5fr 1fr;
      align-items: start;
    }
  }

  .novi-headline {
    font-family: 'Arial Black', system-ui, sans-serif;
    font-weight: 900;
    text-transform: uppercase;
    line-height: 0.85;
    letter-spacing: -0.02em;
    font-size: clamp(4rem, 13vw, 9rem);
    margin: 0 0 1.5rem;
  }

  .novi-headline span {
    display: block;
  }

  .novi-copy {
    max-width: 32ch;
    font-size: 1.0625rem;
    line-height: 1.5;
    color: var(--novi-ink);
  }

  .novi-side-col {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
    gap: 1.25rem;
  }

  .novi-tagline {
    font-size: 1.375rem;
    line-height: 1.25;
    font-weight: 400;
  }

  .novi-visual {
    width: min(100%, 26rem);
    aspect-ratio: 4 / 3;
    position: relative;
    overflow: hidden;
    border-radius: 0.5rem;
    transform: rotate(4deg);
    background: #f4f4f5;
    box-shadow: 0 20px 40px -15px rgb(0 0 0 / 0.35);
  }

  .novi-visual :global(.novi-visual-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .novi-scroll {
    font-family: var(--novi-mono);
    font-size: 1.125rem;
    color: var(--novi-accent);
    background: #000;
    padding: 0.25rem 0.75rem;
    margin-top: -1.5rem;
  }

  .novi-categories {
    position: relative;
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--novi-ink, #0a0a0a);
  }

  .novi-category-row {
    position: relative;
    display: block;
    padding: clamp(1rem, 4vw, 1.75rem) clamp(1.25rem, 4vw, 3rem);
    font-family: system-ui, sans-serif;
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 400;
    line-height: 1;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid #d4d4d8;
    background: #fff;
    transition: background-color 0.2s ease;
  }

  .novi-category-row:nth-child(odd) {
    background: #f4f4f5;
  }

  .novi-category-row:hover {
    background: #e4e4e7;
  }

  .novi-badge {
    position: absolute;
    right: clamp(1rem, 4vw, 2rem);
    bottom: 1.25rem;
    background: #000;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
  }

  @media (max-width: 640px) {
    /* Le texte de la dernière catégorie peut passer sur deux lignes : on réserve de la place
       sous le texte pour que le badge ne le chevauche pas. */
    .novi-category-row:last-of-type {
      padding-bottom: 4.5rem;
    }
  }
</style>
