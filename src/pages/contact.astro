---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Input from '@/components/ui/Input.astro';
---

<BaseLayout title="Contact" description="Contacte l'équipe NOVI pour toute question sur le produit ou ta commande.">
  <section class="mx-auto max-w-2xl px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
    <h1 class="text-ink text-4xl font-bold tracking-tight">Contact</h1>
    <p class="text-muted mt-4">Une question ? Écris-nous, on te répond sous 24h ouvrées.</p>

    <form class="mt-10 flex flex-col gap-5" novalidate>
      <Input id="name" name="name" label="Nom" required autocomplete="name" />
      <Input id="email" name="email" label="Email" type="email" required autocomplete="email" />

      <div class="flex flex-col gap-2">
        <label for="message" class="text-ink text-sm font-medium">Message</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="border-border rounded-brand border px-4 py-3 text-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
        ></textarea>
      </div>

      <button type="submit" class="bg-brand hover:bg-brand-light min-h-[44px] self-start rounded-brand px-6 text-sm font-semibold text-white">
        Envoyer
      </button>
    </form>

    <div class="border-border mt-12 border-t pt-8">
      <h2 class="text-ink text-sm font-semibold">Suivez-nous</h2>
      <div class="mt-3 flex gap-3">
        <a href="#" aria-label="Instagram" class="border-border hover:bg-muted/10 flex h-11 w-11 items-center justify-center rounded-brand border">IG</a>
        <a href="#" aria-label="TikTok" class="border-border hover:bg-muted/10 flex h-11 w-11 items-center justify-center rounded-brand border">TT</a>
      </div>
    </div>
  </section>
</BaseLayout>
