---
import Button from '@/components/ui/Button.astro';
---

<section class="bg-ink py-16 lg:py-20">
  <div class="mx-auto max-w-2xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Prêt à emporter la fraîcheur partout ?</h2>
    <p class="mt-3 text-white/70">Précommande ton PULP dès aujourd'hui, ou reste informé de nos prochaines offres.</p>

    <div class="mt-8 flex justify-center">
      <Button href="/produit" size="lg" class="text-ink !bg-white hover:!bg-white/90">Acheter maintenant</Button>
    </div>

    <form class="mx-auto mt-10 flex max-w-md flex-col gap-3 sm:flex-row" novalidate>
      <label for="newsletter-email" class="sr-only">Adresse email</label>
      <input
        id="newsletter-email"
        name="email"
        type="email"
        required
        autocomplete="email"
        inputmode="email"
        placeholder="ton@email.com"
        class="min-h-[44px] flex-1 rounded-brand border border-white/20 bg-white/10 px-4 text-sm text-white placeholder:text-white/50 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
      />
      <button type="submit" class="text-ink min-h-[44px] rounded-brand bg-white px-6 text-sm font-semibold hover:bg-white/90">
        S'inscrire
      </button>
    </form>
    <p class="mt-3 text-xs text-white/50">Pas de spam, désinscription en un clic.</p>
  </div>
</section>
