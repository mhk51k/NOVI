---
import { getEntry } from 'astro:content';
import { formatPrice } from '@/lib/formatPrice';

const entry = await getEntry('products', 'novi-enceinte');
if (!entry) throw new Error('Produit introuvable : novi-enceinte');
const product = entry.data;
const frontImage = product.images[1] ?? product.images[0];
const angleImage = product.images[0];
const defaultVariant = product.colorVariants[0];
---

<section class="quickbuy">
  <div class="mx-auto grid max-w-container items-center gap-10 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:gap-16 lg:px-8 lg:py-20">
    <div class="quickbuy-spin-wrap">
      <div class="quickbuy-stage">
        <img
          src={frontImage.src}
          alt={frontImage.alt}
          class="quickbuy-spin-img quickbuy-img-front"
          width="480"
          height="360"
          loading="lazy"
        />
        <img
          src={angleImage.src}
          alt=""
          aria-hidden="true"
          class="quickbuy-spin-img quickbuy-img-angle"
          width="480"
          height="360"
          loading="lazy"
        />
        <div class="quickbuy-sheen" aria-hidden="true"></div>
      </div>
      <div class="quickbuy-shadow" aria-hidden="true"></div>
    </div>

    <div class="flex flex-col items-center gap-4 text-center lg:items-start lg:text-left">
      <p class="text-muted text-sm font-medium">{product.title} — {defaultVariant.name}</p>
      <p class="text-ink text-4xl font-bold tracking-tight sm:text-5xl">
        {formatPrice(product.price, product.currency)}
      </p>

      <button type="button" class="quickbuy-pay-btn" data-pay-button data-sku={defaultVariant.sku}>
        Payer maintenant
      </button>
      <p class="text-muted min-h-[1.25rem] text-sm" data-pay-note aria-live="polite"></p>
    </div>
  </div>
</section>

<script>
  const button = document.querySelector<HTMLButtonElement>('[data-pay-button]');
  const note = document.querySelector<HTMLElement>('[data-pay-note]');

  button?.addEventListener('click', async () => {
    const originalLabel = button.textContent;
    button.disabled = true;
    button.textContent = 'Redirection…';
    if (note) note.textContent = '';

    try {
      const response = await fetch('/api/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sku: button.dataset.sku, quantity: 1 }),
      });
      const data = await response.json().catch(() => null);

      if (response.ok && data?.url) {
        window.location.href = data.url;
        return;
      }

      if (note) {
        note.textContent = data?.error ?? "Le paiement n'est pas encore disponible sur cette version du site.";
      }
    } catch {
      if (note) note.textContent = 'Une erreur est survenue, réessaie plus tard.';
    } finally {
      button.disabled = false;
      button.textContent = originalLabel;
    }
  });
</script>

<style>
  .quickbuy {
    background: var(--color-surface);
  }

  .quickbuy-spin-wrap {
    margin: 0 auto;
    width: min(100%, 22rem);
    perspective: 1400px;
  }

  .quickbuy-stage {
    position: relative;
    aspect-ratio: 4 / 3;
    animation: quickbuy-tilt 6s ease-in-out infinite;
    transform-style: preserve-3d;
    will-change: transform;
  }

  .quickbuy-spin-wrap:hover .quickbuy-stage {
    animation-play-state: paused;
  }

  .quickbuy-spin-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .quickbuy-img-front {
    animation: quickbuy-fade-front 6s ease-in-out infinite;
  }

  .quickbuy-img-angle {
    animation: quickbuy-fade-angle 6s ease-in-out infinite;
  }

  .quickbuy-shadow {
    width: 70%;
    height: 1.25rem;
    margin: 0.5rem auto 0;
    border-radius: 50%;
    background: radial-gradient(closest-side, rgb(0 0 0 / 0.18), transparent 70%);
    animation: quickbuy-shadow-move 6s ease-in-out infinite;
  }

  .quickbuy-spin-wrap:hover .quickbuy-shadow,
  .quickbuy-spin-wrap:hover .quickbuy-sheen {
    animation-play-state: paused;
  }

  .quickbuy-sheen {
    position: absolute;
    inset: 0;
    background: linear-gradient(115deg, transparent 30%, rgb(255 255 255 / 0.65) 48%, transparent 66%);
    background-size: 220% 100%;
    mix-blend-mode: screen;
    opacity: 0;
    pointer-events: none;
    animation: quickbuy-sheen-move 6s ease-in-out infinite;
  }

  /* Rotation subtile (± ~24°) plutôt qu'un tour complet : une photo à plat déformée à
     90°/270° a l'air fausse. On reste proche de l'angle réellement photographié, on fait
     un fondu enchaîné vers la vraie vue 3/4, et on ajoute un reflet + une ombre qui bougent
     avec la rotation pour renforcer l'illusion de volume. */
  @keyframes quickbuy-tilt {
    0%,
    100% {
      transform: rotateY(0deg) scale(1);
    }
    50% {
      transform: rotateY(24deg) scale(0.98);
    }
  }

  @keyframes quickbuy-fade-front {
    0%,
    100% {
      opacity: 1;
    }
    40%,
    60% {
      opacity: 0;
    }
  }

  @keyframes quickbuy-fade-angle {
    0%,
    100% {
      opacity: 0;
    }
    40%,
    60% {
      opacity: 1;
    }
  }

  @keyframes quickbuy-sheen-move {
    0%,
    100% {
      background-position: 140% 0;
      opacity: 0;
    }
    45%,
    55% {
      opacity: 0;
    }
    50% {
      background-position: -40% 0;
      opacity: 0.9;
    }
  }

  @keyframes quickbuy-shadow-move {
    0%,
    100% {
      transform: scaleX(1) translateX(0);
      opacity: 0.18;
    }
    50% {
      transform: scaleX(0.82) translateX(4%);
      opacity: 0.26;
    }
  }

  .quickbuy-pay-btn {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-brand);
    background: var(--color-brand);
    padding: 0.875rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
    transition: background-color 0.2s ease;
  }

  .quickbuy-pay-btn:hover:not(:disabled) {
    background: var(--color-brand-light);
  }

  .quickbuy-pay-btn:disabled {
    opacity: 0.7;
    cursor: default;
  }
</style>
