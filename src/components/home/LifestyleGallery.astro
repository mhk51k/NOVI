---
const scenes = [
  { label: 'Sport', src: '/assets/produit/pulp-lifestyle-sport.svg' },
  { label: 'Bureau', src: '/assets/produit/pulp-lifestyle-bureau.svg' },
  { label: 'Plage', src: '/assets/produit/pulp-lifestyle-plage.svg' },
  { label: 'Maison', src: '/assets/produit/pulp-lifestyle-maison.svg' },
];
---

<section class="bg-muted/5 py-16 lg:py-24">
  <div class="mx-auto max-w-container px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-ink text-3xl font-bold tracking-tight sm:text-4xl">PULP s'adapte à toi</h2>
      <p class="text-muted mt-3">Un seul mixeur, tous les contextes.</p>
    </div>
    <div class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        scenes.map((scene) => (
          <div class="reveal border-border bg-surface aspect-[3/4] overflow-hidden rounded-brand border">
            <img
              src={scene.src}
              alt={`PULP utilisé — ${scene.label}`}
              class="h-full w-full object-cover"
              loading="lazy"
              width="400"
              height="533"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>
