---
const benefits = [
  {
    title: 'Autonomie longue durée',
    description: "Jusqu'à 15 mixages avant de recharger, en USB-C.",
    highlight: true,
  },
  { title: 'Puissance réelle', description: 'Un moteur 20 000 tr/min qui mixe fruits et glace sans forcer.' },
  { title: 'Lavage en 20 secondes', description: "Eau + savon, on secoue, c'est propre." },
  { title: 'Compact et léger', description: '420g, format bouteille, il se glisse partout.' },
  { title: 'Ultra simple', description: 'Un seul bouton, aucun réglage à comprendre.' },
  { title: 'Pensé sécurité', description: 'Lames protégées, arrêt automatique si mal fermé.' },
];
---

<section class="bg-muted/5 py-16 lg:py-24">
  <div class="mx-auto max-w-container px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-ink text-3xl font-bold tracking-tight sm:text-4xl">Fait pour ton quotidien</h2>
      <p class="text-muted mt-3">Les détails qui rendent PULP simple à adopter, tous les jours.</p>
    </div>
    <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        benefits.map((benefit) => (
          <div class:list={['reveal border-border bg-surface rounded-brand border p-6', benefit.highlight && 'lg:col-span-2']}>
            <h3 class="text-ink text-lg font-semibold">{benefit.title}</h3>
            <p class="text-muted mt-2 text-sm">{benefit.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
