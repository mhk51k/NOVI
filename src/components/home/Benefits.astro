---
const benefits = [
  {
    title: 'Autonomie longue durée',
    description: "Jusqu'à 20h d'écoute avant de recharger, en USB-C.",
    highlight: true,
  },
  { title: 'Son puissant', description: 'Haut-parleur 20W avec basses renforcées par radiateur passif.' },
  { title: 'Résistante à l\'eau', description: "Étanchéité IPX7, elle suit à la plage comme sous la pluie." },
  { title: 'Compacte et légère', description: '540g, elle se glisse dans un sac comme dans une main.' },
  { title: 'Ultra simple', description: 'Appairage Bluetooth en quelques secondes, aucun réglage à comprendre.' },
  { title: 'Connectivité complète', description: 'Bluetooth 5.3 ou câble jack 3,5 mm, au choix.' },
];
---

<section class="bg-muted/5 py-16 lg:py-24">
  <div class="mx-auto max-w-container px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-ink text-3xl font-bold tracking-tight sm:text-4xl">Fait pour ton quotidien</h2>
      <p class="text-muted mt-3">Les détails qui rendent NOVI simple à adopter, tous les jours.</p>
    </div>
    <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        benefits.map((benefit) => (
          <div class:list={['reveal border-border bg-surface rounded-brand border p-6', benefit.highlight && 'lg:col-span-2']}>
            <h3 class="text-ink text-lg font-semibold">{benefit.title}</h3>
            <p class="text-muted mt-2 text-sm">{benefit.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
