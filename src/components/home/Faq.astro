---
const faqs = [
  { q: 'Combien de temps dure la batterie ?', a: "Jusqu'à 20h d'écoute à volume modéré avec une charge complète (environ 2h30 en USB-C)." },
  {
    q: 'L\'enceinte résiste-t-elle à l\'eau ?',
    a: "Oui, NOVI est certifiée IPX7 : elle résiste aux éclaboussures, à la pluie et à une immersion accidentelle brève.",
  },
  { q: 'Quelle est la garantie ?', a: "NOVI est garantie 2 ans pièces et main d'œuvre." },
  { q: 'Sous combien de temps suis-je livré ?', a: 'Entre 3 et 5 jours ouvrés en France métropolitaine.' },
  { q: 'Comment connecter l\'enceinte ?', a: 'Maintiens le bouton Bluetooth 3 secondes, puis sélectionne NOVI dans les paramètres Bluetooth de ton téléphone.' },
  { q: 'Puis-je l\'utiliser avec un câble ?', a: "Oui, une prise jack 3,5 mm permet un branchement filaire avec le câble AUX inclus." },
];
---

<section id="faq" class="bg-surface py-16 lg:py-24">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-ink text-center text-3xl font-bold tracking-tight sm:text-4xl">Questions fréquentes</h2>
    <div class="divide-border border-border mt-10 divide-y border-t">
      {
        faqs.map((faq) => (
          <details class="group py-5">
            <summary class="text-ink flex cursor-pointer list-none items-center justify-between gap-4 text-left font-semibold marker:content-none">
              {faq.q}
              <span class="text-muted text-xl transition-transform group-open:rotate-45" aria-hidden="true">
                +
              </span>
            </summary>
            <p class="text-muted mt-3 text-sm">{faq.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
