---
interface GalleryImage {
  src: string;
  alt: string;
}

interface Props {
  images: GalleryImage[];
}

const { images } = Astro.props;
const [main, ...rest] = images;
---

<div class="flex flex-col gap-3">
  <div class="bg-muted/5 border-border aspect-square w-full overflow-hidden rounded-brand border">
    <img src={main.src} alt={main.alt} class="h-full w-full object-contain" width="600" height="600" loading="eager" />
  </div>
  {
    rest.length > 0 && (
      <div class="grid grid-cols-3 gap-3">
        {rest.map((img) => (
          <div class="bg-muted/5 border-border aspect-square overflow-hidden rounded-brand border">
            <img src={img.src} alt={img.alt} class="h-full w-full object-contain" width="200" height="200" loading="lazy" />
          </div>
        ))}
      </div>
    )
  }
</div>
