---
interface Props {
  id: string;
  name: string;
  label: string;
  type?: 'text' | 'email' | 'tel' | 'search';
  required?: boolean;
  autocomplete?: string;
  class?: string;
}

const { id, name, label, type = 'text', required = false, autocomplete, class: className = '' } = Astro.props;
---

<div class="flex flex-col gap-2">
  <label for={id} class="text-sm font-medium text-ink">{label}</label>
  <input
    id={id}
    name={name}
    type={type}
    required={required}
    autocomplete={autocomplete}
    class:list={[
      'min-h-[44px] rounded-brand border border-border px-4 text-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand',
      className,
    ]}
  />
</div>
