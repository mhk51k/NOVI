---
import Button from '@/components/ui/Button.astro';
import Logo from '@/components/ui/Logo.astro';
import MobileNav from '@/components/layout/MobileNav.svelte';
import CartIcon from '@/components/cart/CartIcon.svelte';

const navItems = [
  { href: '/produit', label: 'Produit' },
  { href: '/#comment-ca-marche', label: 'Comment ça marche' },
  { href: '/#avis', label: 'Avis' },
  { href: '/a-propos', label: 'À propos' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="border-border bg-surface/90 sticky top-0 z-40 border-b backdrop-blur">
  <div class="mx-auto flex max-w-container items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
    <a href="/" class="flex h-10 items-center" aria-label="NOVI — retour à l'accueil">
      <Logo class="text-2xl" />
    </a>

    <nav class="hidden items-center gap-8 lg:flex" aria-label="Navigation principale">
      {navItems.map((item) => <a href={item.href} class="text-ink hover:text-brand text-sm font-medium">{item.label}</a>)}
    </nav>

    <div class="flex items-center gap-3">
      <Button href="/produit" size="md" class="hidden sm:inline-flex">Acheter</Button>
      <CartIcon client:load />
      <!-- client:only : évite un mismatch d'hydratation avec les blocs conditionnels du composant -->
      <MobileNav client:only="svelte" navItems={navItems} />
    </div>
  </div>
</header>
