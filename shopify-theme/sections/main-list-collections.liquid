<section class="section">
  <div class="container">
    <div class="section__head">
      <h1 style="font-size:2rem;font-weight:700;margin:0 0 0.5rem;">Nos collections</h1>
    </div>
    <div class="benefits-grid">
      {% for collection in collections %}
        <a href="{{ collection.url }}" class="benefit-card" style="display:block;">
          <h3>{{ collection.title }}</h3>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{ "name": "Liste des collections", "settings": [] }
{% endschema %}
