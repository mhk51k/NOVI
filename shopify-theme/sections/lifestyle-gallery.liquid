<section class="section section--alt">
  <div class="container">
    <div class="section__head">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subheading }}</p>
    </div>
    <div class="lifestyle-grid">
      {% for block in section.blocks %}
        <div class="lifestyle-grid__item" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <img
              src="{{ block.settings.image | image_url: width: 400 }}"
              alt="NOVI utilisée — {{ block.settings.label }}"
              width="400"
              height="533"
              loading="lazy"
            />
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Galerie lifestyle",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titre", "default": "NOVI s'adapte à toi" },
    { "type": "text", "id": "subheading", "label": "Sous-titre", "default": "Une seule enceinte, tous les contextes." }
  ],
  "blocks": [
    {
      "type": "scene",
      "name": "Scène",
      "settings": [
        { "type": "text", "id": "label", "label": "Libellé" },
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Galerie lifestyle",
      "blocks": [
        { "type": "scene", "settings": { "label": "Sport" } },
        { "type": "scene", "settings": { "label": "Bureau" } },
        { "type": "scene", "settings": { "label": "Plage" } },
        { "type": "scene", "settings": { "label": "Maison" } }
      ]
    }
  ]
}
{% endschema %}
