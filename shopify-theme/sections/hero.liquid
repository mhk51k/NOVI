<section class="hero">
  <div class="container hero__grid">
    <div>
      {% if section.settings.badge != blank %}
        <span class="hero__badge">{{ section.settings.badge }}</span>
      {% endif %}
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.subheading }}</p>
      <div class="hero__ctas">
        {% if section.settings.primary_label != blank %}
          <a href="{{ section.settings.primary_url | default: routes.all_products_collection_url }}" class="btn btn-primary btn-lg">
            {{ section.settings.primary_label }}
          </a>
        {% endif %}
        {% if section.settings.secondary_label != blank %}
          <a href="{{ section.settings.secondary_url | default: '#comment-ca-marche' }}" class="btn btn-secondary btn-lg">
            {{ section.settings.secondary_label }}
          </a>
        {% endif %}
      </div>
      {% if section.settings.meta != blank %}
        <p class="hero__meta">{{ section.settings.meta }}</p>
      {% endif %}
    </div>

    <div class="hero__media">
      {% if section.settings.image != blank %}
        <img
          src="{{ section.settings.image | image_url: width: 900 }}"
          alt="{{ section.settings.image.alt | default: section.settings.heading }}"
          width="600"
          height="600"
          loading="eager"
        />
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge", "default": "Nouveau — précommande ouverte" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "Ton son, où que tu sois" },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "NOVI est l'enceinte portable Bluetooth au son puissant et à l'autonomie longue durée, à la maison comme en déplacement."
    },
    { "type": "text", "id": "primary_label", "label": "Bouton principal", "default": "Acheter maintenant" },
    { "type": "url", "id": "primary_url", "label": "Lien du bouton principal" },
    { "type": "text", "id": "secondary_label", "label": "Bouton secondaire", "default": "Comment ça marche" },
    { "type": "url", "id": "secondary_url", "label": "Lien du bouton secondaire" },
    {
      "type": "text",
      "id": "meta",
      "label": "Texte de réassurance",
      "default": "Livraison offerte dès 40€ · Garantie 2 ans · Paiement sécurisé"
    },
    { "type": "image_picker", "id": "image", "label": "Image du produit" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
