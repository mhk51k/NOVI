<section class="section">
  <div class="container">
    <div class="section__head">
      <h1 style="font-size:2rem;font-weight:700;margin:0 0 0.5rem;">{{ collection.title }}</h1>
      {% if collection.description != blank %}<p>{{ collection.description }}</p>{% endif %}
    </div>

    {% if collection.products.size == 0 %}
      <p style="text-align:center;color:var(--color-muted);">Aucun produit pour le moment.</p>
    {% else %}
      <div class="benefits-grid">
        {% for product in collection.products %}
          <a href="{{ product.url }}" class="benefit-card" style="display:block;">
            <div style="aspect-ratio:1/1;overflow:hidden;border-radius:var(--radius-brand);background:var(--color-surface-alt);margin-bottom:0.75rem;">
              <img
                src="{{ product.featured_image | image_url: width: 400 }}"
                alt="{{ product.featured_image.alt | default: product.title }}"
                width="400"
                height="400"
                loading="lazy"
                style="width:100%;height:100%;object-fit:contain;"
              />
            </div>
            <h3>{{ product.title }}</h3>
            <p>{{ product.price_min | money }}</p>
          </a>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{ "name": "Collection", "settings": [] }
{% endschema %}
