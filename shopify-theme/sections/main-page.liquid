<section class="basic-page">
  <h1>{{ page.title }}</h1>
  <div class="basic-page__content">{{ page.content }}</div>

  {% if page.handle == 'contact' %}
    {% form 'contact' %}
      {% if form.posted_successfully? %}
        <p style="color: var(--color-brand); font-weight: 600;">Merci, ton message a bien été envoyé ✓</p>
      {% endif %}
      <div class="contact-form">
        <div>
          <label for="ContactFormName">Nom</label>
          <input type="text" id="ContactFormName" name="contact[name]" autocomplete="name" required />
        </div>
        <div>
          <label for="ContactFormEmail">Email</label>
          <input type="email" id="ContactFormEmail" name="contact[email]" autocomplete="email" required />
        </div>
        <div>
          <label for="ContactFormMessage">Message</label>
          <textarea id="ContactFormMessage" name="contact[body]" rows="5" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Envoyer</button>
      </div>
    {% endform %}
  {% endif %}
</section>

{% schema %}
{
  "name": "Page",
  "settings": []
}
{% endschema %}
