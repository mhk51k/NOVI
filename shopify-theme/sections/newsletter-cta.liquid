<section class="newsletter">
  <div class="container newsletter__inner">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subheading }}</p>

    <a href="{{ section.settings.button_url | default: routes.all_products_collection_url }}" class="btn btn-primary btn-lg">
      {{ section.settings.button_label }}
    </a>

    {% form 'customer' %}
      {% if form.posted_successfully? %}
        <p class="newsletter__fine">Merci, tu es inscrit·e ✓</p>
      {% endif %}
      <input type="hidden" name="contact[tags]" value="newsletter" />
      <label for="newsletter-email" class="visually-hidden">Adresse email</label>
      <input
        id="newsletter-email"
        type="email"
        name="contact[email]"
        placeholder="ton@email.com"
        autocomplete="email"
        required
      />
      <button type="submit" class="btn btn-primary">S'inscrire</button>
    {% endform %}
    <p class="newsletter__fine">Pas de spam, désinscription en un clic.</p>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titre", "default": "Prêt à emporter ton son partout ?" },
    { "type": "textarea", "id": "subheading", "label": "Sous-titre", "default": "Précommande ton NOVI dès aujourd'hui, ou reste informé de nos prochaines offres." },
    { "type": "text", "id": "button_label", "label": "Bouton", "default": "Acheter maintenant" },
    { "type": "url", "id": "button_url", "label": "Lien du bouton" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
