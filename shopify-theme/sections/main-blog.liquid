<section class="section">
  <div class="container">
    <div class="section__head">
      <h1 style="font-size:2rem;font-weight:700;margin:0 0 0.5rem;">{{ blog.title }}</h1>
    </div>
    <div class="benefits-grid">
      {% for article in blog.articles %}
        <a href="{{ article.url }}" class="benefit-card" style="display:block;">
          <h3>{{ article.title }}</h3>
          <p>{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{ "name": "Blog", "settings": [] }
{% endschema %}
