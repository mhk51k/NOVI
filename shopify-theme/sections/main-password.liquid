<section class="basic-page" style="text-align:center;">
  <span class="novi-logo" style="justify-content:center;">N<span class="novi-logo-o">O</span>V<span class="novi-logo-i">I</span></span>
  <p class="basic-page__content" style="margin-top:1rem;">Notre boutique arrive bientôt.</p>

  {% form 'storefront_password' %}
    {% if form.errors %}
      <p style="color:#b91c1c;">Mot de passe incorrect.</p>
    {% endif %}
    <div class="contact-form" style="max-width:24rem;margin:1.5rem auto 0;">
      <div>
        <label for="Password" class="visually-hidden">Mot de passe</label>
        <input type="password" id="Password" name="password" placeholder="Mot de passe" />
      </div>
      <button type="submit" class="btn btn-primary">Entrer</button>
    </div>
  {% endform %}
</section>

{% schema %}
{ "name": "Mot de passe", "settings": [] }
{% endschema %}
